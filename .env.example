VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudinary — 25 Go gratuits pour les images
# 1. Crée un compte sur https://cloudinary.com
# 2. Va dans Settings > Upload > Upload presets > Enable unsigned uploading
# 3. Copie ton Cloud name (tableau de bord) et le nom du preset
VITE_CLOUDINARY_CLOUD_NAME=votre-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=arteia_unsigned

# Neon — BDD PostgreSQL secondaire gratuite (3 Go)
# 1. Crée un compte sur https://neon.tech
# 2. Crée un projet et copie la connection string
# 3. Déploie l'edge function : supabase functions deploy neon-proxy
# 4. Ajoute NEON_DATABASE_URL dans les secrets Supabase :
#    supabase secrets set NEON_DATABASE_URL=postgresql://...
VITE_NEON_ENABLED=true
